# ============================================================
# 环境变量 & 密钥（严禁上传，使用 .env.example 作为模板）
# ============================================================
.env
.env.*
!.env.example

# ============================================================
# Go 编译产物
# ============================================================
# 根目录编译出的可执行二进制
/agent

# go build / go test 中间产物
*.test
*.out
/bin/

# 测试覆盖率报告
coverage.html
coverage/

# ============================================================
# 运行时缓存 & 持久化数据
# ============================================================
cache/*
!cache/.gitkeep

# ============================================================
# Claude Code 本地配置（个人工作区设置，不共享）
# ============================================================
.claude/

# ============================================================
# 前端构建产物（web/ 子目录的 .gitignore 已覆盖，此处加固）
# ============================================================
web/node_modules/
web/dist/
web/dist-ssr/

# ============================================================
# macOS 系统文件
# ============================================================
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
Thumbs.db

# ============================================================
# IDE & 编辑器
# ============================================================
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================
# 操作系统 & 临时文件
# ============================================================
*.tmp
*.bak
*.orig
