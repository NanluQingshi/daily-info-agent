# ============================================================
# daily-info-agent — environment variable reference
# Copy this file to .env and fill in real values for local dev.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# LLM：中科大 LLM 平台（必填）
# 接口文档：https://api.llm.ustc.edu.cn
# ------------------------------------------------------------

# API Key（从平台申请）
LLM_API_KEY=

# 可用模型（经验证可用，2026-06）：
#   推荐：deepseek-v4-pro（支持 Function Calling，适合 Agent 模式）
#   快速备选：deepseek-v4-flash-ascend / qwen-chat
#   推理模型：qwen3.6-reasoner / qwen-reasoner（content 字段可能为空，需读 reasoning_content）
#   智能路由：smart/default / smart/reasoning
#
#   注意：glm-5.2 / glm-chat 当前不可用（平台 404）
LLM_MODEL_ID=deepseek-v4-pro

# API base URL
LLM_BASE_URL=https://api.llm.ustc.edu.cn/v1

# ------------------------------------------------------------
# Data Sources
# ------------------------------------------------------------

# NewsAPI v2 API key (required).
# Obtain from: https://newsapi.org/register
NEWSAPI_KEY=

# Base URL of your RSSHub instance (optional).
# NOTE: https://rsshub.app (the public instance) is blocked in mainland China.
# Self-host RSSHub via Docker: docker run -d -p 1200:1200 diygod/rsshub
# Then set: RSSHUB_BASE_URL=http://localhost:1200
RSSHUB_BASE_URL=https://rsshub.app

# Semicolon-separated RSSHub route paths (optional).
# These are appended to RSSHUB_BASE_URL at runtime. Requires a working
# RSSHUB_BASE_URL (see above). If unset, the built-in route list is used.
# Built-in routes cover: 华尔街见闻, 财联社, 金十, 36氪, 虎嗅, 联合早报, 新华社
# Example (self-hosted instance):
# RSSHUB_ROUTES=/wallstreetcn/news/global;/cls/telegraph;/jin10/flash_news;/36kr/news/technology
RSSHUB_ROUTES=

# Semicolon-separated list of direct RSS feed URLs to fetch (optional).
# If unset, the built-in list of Chinese news feeds is used:
#   36氪, 少数派, 爱范儿, cnBeta, 虎嗅, 观察者网, PingWest, 人民日报(政治+财经)
# Example:
# RSS_FEEDS=https://36kr.com/feed;https://rss.huxiu.com/;https://www.guancha.cn/rss.xml
RSS_FEEDS=

# ------------------------------------------------------------
# Source Verification
# ------------------------------------------------------------

# Comma-separated list of trusted source domains (optional).
# Items from these domains bypass the AI credibility-score check.
# If unset, the built-in whitelist is used.
# Example:
# TRUSTED_DOMAINS=xinhua.net,people.com.cn,gov.cn,reuters.com,bbc.com,theverge.com
TRUSTED_DOMAINS=

# Set to "true" to bypass all credibility checks (debug/testing only).
# Default: false
SKIP_VERIFICATION=false

# ------------------------------------------------------------
# Scheduled Mode
# ------------------------------------------------------------

# Comma-separated list of categories to process in scheduled mode (optional).
# Valid values: 金融, 政治, 经济, 科技/AI, 国际
# Default: all five categories
DEFAULT_CATEGORIES=金融,政治,经济,科技/AI,国际

# ------------------------------------------------------------
# Database (optional — required for article persistence and GUI)
# ------------------------------------------------------------

# PostgreSQL 连接串（可选，不填则不持久化，schedule 模式仍可正常运行）
# macOS 本地示例（用系统用户名，非 postgres）：
#   createdb daily_info
#   DATABASE_DSN=postgres://$(whoami)@localhost:5432/daily_info?sslmode=disable
DATABASE_DSN=

# ------------------------------------------------------------
# Publishing: Java Website API (optional)
# ------------------------------------------------------------

# Base URL of the Java Spring Boot website API (no trailing slash).
# Leave blank to disable Java API publishing (local-first mode).
WEBSITE_API_BASE_URL=

# Bearer token used for authenticating requests to the website API.
WEBSITE_API_TOKEN=

# ------------------------------------------------------------
# Email Notifications (optional — leave blank to disable)
# ------------------------------------------------------------

# SMTP server hostname (e.g. smtp.gmail.com, smtp.qq.com).
# Leave blank to disable email digests entirely.
SMTP_HOST=

# SMTP server port. Default: 587 (STARTTLS). Use 465 for SSL.
SMTP_PORT=587

# SMTP authentication credentials.
SMTP_USER=
SMTP_PASSWORD=

# Sender address shown in the "From" field (optional; defaults to SMTP_USER).
SMTP_FROM=

# Recipient address for the daily summary email.
NOTIFY_EMAIL=

# ------------------------------------------------------------
# HTTP Server (conversational mode)
# ------------------------------------------------------------

# Address for the HTTP server to listen on.
# Default: 127.0.0.1:8080 (loopback only)
# Set to 0.0.0.0:8080 to expose externally (e.g. behind a reverse proxy).
BIND_ADDR=127.0.0.1:8080

# Optional shared secret for /api/chat and /api/chat/stream.
# When set, requests must carry it in the "X-Api-Token" header
# or as "Authorization: Bearer <token>". Leave blank to disable auth
# (only safe when BIND_ADDR is loopback).
CHAT_API_TOKEN=

# Optional per-IP rate limit on the chat endpoints, in requests per minute.
# 0 disables limiting. Each chat turn can fan out into several LLM calls, so
# a small value (e.g. 10) is usually enough for one user.
CHAT_RATE_LIMIT_PER_MIN=0

# ------------------------------------------------------------
# Observability
# ------------------------------------------------------------

# Minimum log level: DEBUG, INFO, WARN, ERROR
# Default: INFO
LOG_LEVEL=INFO

# ------------------------------------------------------------
# Runtime / Caching
# ------------------------------------------------------------

# Path to the URL deduplication cache file.
# Default: cache/dedup.json
CACHE_FILE_PATH=cache/dedup.json
